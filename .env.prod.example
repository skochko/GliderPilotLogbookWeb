# Copy to .env.prod
# Usage: docker compose -f docker-compose.yml -f docker-compose.prod.yml --env-file .env.prod up -d --build

# Bind to localhost only — host nginx listens on :80 and proxies here
WEB_HTTP_PORT=127.0.0.1:8080:80

# Backend API URL (external; baked into the image at build time)
VITE_API_URL=https://api.example.com/api

# Public Google credentials for Picker (same OAuth client as backend)
VITE_GOOGLE_CLIENT_ID=
VITE_GOOGLE_API_KEY=
