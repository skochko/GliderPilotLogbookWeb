# Copy to .env.staging
# Usage: docker compose -f docker-compose.yml -f docker-compose.staging.yml --env-file .env.staging up -d --build

WEB_HTTP_PORT=8080

# Backend API URL (external; baked into the image at build time)
VITE_API_URL=https://api-staging.example.com/api

# Public Google credentials for Picker (same OAuth client as backend)
VITE_GOOGLE_CLIENT_ID=
VITE_GOOGLE_API_KEY=
